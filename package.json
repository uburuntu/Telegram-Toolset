{
  "name": "telegram-toolset",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .vue,.js,.ts,.tsx",
    "lint:fix": "eslint src --ext .vue,.js,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,json}\"",
    "test": "npm run test:unit && npm run test:component",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:component": "vitest run --config vitest.config.component.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "idb": "latest",
    "jszip": "latest",
    "pinia": "latest",
    "streamsaver": "latest",
    "telegram": "latest",
    "uuid": "latest",
    "vue": "latest",
    "vue-i18n": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@tailwindcss/vite": "latest",
    "@types/node": "latest",
    "@types/streamsaver": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "@vitejs/plugin-vue": "latest",
    "@vitest/coverage-v8": "latest",
    "@vue/test-utils": "latest",
    "@vue/tsconfig": "latest",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "latest",
    "jsdom": "latest",
    "postcss": "latest",
    "prettier": "^3.7.4",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "vue-tsc": "latest"
  }
}
